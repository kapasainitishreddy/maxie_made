# PegWatch API configuration
# Copy to .env and fill in your own values

# Core
APP_NAME="PegWatch API"
ENVIRONMENT=development
DEBUG=true
API_V1_PREFIX=/api/v1

# Database (SQLite default; swap to Postgres for prod)
DATABASE_URL=sqlite+aiosqlite:///./pegwatch.db
# DATABASE_URL=postgresql+asyncpg://user:pass@host:5432/pegwatch

# Auth (Clerk) - leave empty for dev bypass
CLERK_SECRET_KEY=
CLERK_PUBLISHABLE_KEY=
ALLOW_DEV_AUTH=true

# Stripe (leave empty for dev bypass)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_PRO=
STRIPE_PRICE_API=

# Ollama (local AI for incident summaries, $0 cost)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=qwen3:8b

# Alert delivery (all optional in dev)
TELEGRAM_BOT_TOKEN=
DISCORD_WEBHOOK_URL=
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
ALERT_FROM_EMAIL=alerts@pegwatch.dev

# Security
SECRET_KEY=change-me-in-production-use-openssl-rand-hex-32
ALLOWED_ORIGINS=http://localhost:3004,https://pegwatch.dev

# Observability (optional)
SENTRY_DSN=
LOG_LEVEL=INFO
