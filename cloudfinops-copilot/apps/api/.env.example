# =============================================================================
# CloudFinOps Co-Pilot — env template
# =============================================================================

# --- Core ---
APP_NAME="CloudFinOps Co-Pilot API"
ENVIRONMENT=development
DEBUG=true

# --- Database: Neon Postgres (free 0.5GB) ---
DATABASE_URL=postgresql+asyncpg://USER:PASS@HOST/DBNAME?sslmode=require

# --- Redis: Upstash (free 10k cmd/day) ---
REDIS_URL=rediss://default:PASS@HOST.upstash.io:6379

# --- Clerk Auth (free up to 10k MAU) ---
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_xxx
CLERK_SECRET_KEY=*** --- AWS (read-only cross-account role) ---
AWS_ACCESS_KEY_ID=*** AWS_SECRET_ACCESS_KEY=*** AWS_REGION=us-east-1

# --- Stripe ---
STRIPE_SECRET_KEY=*** --- CORS ---
CORS_ORIGINS=["http://localhost:3000"]

# --- Slack OAuth ---
SLACK_BOT_TOKEN=*** SLACK_SIGNING_SECRET=*** SLACK_CLIENT_ID=*** SLACK_CLIENT_SECRET=*** CORS_ORIGINS=["http://localhost:3000"]
