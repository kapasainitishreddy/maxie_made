# =============================================================================
# PharmaIP Radar — env template. Copy to .env and fill in.
# All listed services have generous free tiers; total $0 to launch.
# =============================================================================

# --- Core ---
APP_NAME="PharmaIP Radar API"
ENVIRONMENT=development
DEBUG=true

# --- Database: Neon Postgres (free 0.5GB) ---
# Get a free DB: https://neon.tech
DATABASE_URL=postgresql+asyncpg://USER:PASS@HOST/DBNAME?sslmode=require

# --- Redis: Upstash (free 10k cmd/day) ---
REDIS_URL=rediss://default:PASS@HOST.upstash.io:6379

# --- Clerk Auth (free up to 10k MAU) ---
# Get keys: https://dashboard.clerk.com
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_xxx
CLERK_SECRET_KEY=sk_test_xxx
CLERK_JWKS_URL=https://api.clerk.com/v1/jwks

# --- Stripe (no monthly fee) ---
# Get keys: https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=sk_test_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx
STRIPE_PRICE_STARTER=price_xxx_starter
STRIPE_PRICE_PRO=price_xxx_pro
STRIPE_PRICE_ENTERPRISE=price_xxx_enterprise

# --- External data sources ---
# USPTO Open Data: https://data.uspto.gov/
USPTO_API_KEY=
# PubMed E-utilities: register for an API key to lift rate limits
PUBMED_API_KEY=

# --- CORS ---
CORS_ORIGINS=["http://localhost:3000"]

# --- LLM (local, $0) ---
OLLAMA_HOST=http://localhost:11434
OLLAMA_MODEL=qwen3:8b
