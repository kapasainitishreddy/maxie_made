# =====================================================
# Shared env template for all maxie_made apps.
# Copy to each app folder as .env and fill in the keys.
# All listed services have generous free tiers.
# =====================================================

# ----- Clerk Auth (free up to 10k MAU) -----
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_xxx
CLERK_SECRET_KEY=sk_test_xxx

# ----- Stripe (no monthly fee, 2.9% + 30c per txn) -----
STRIPE_SECRET_KEY=sk_test_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_xxx

# ----- Database: Neon Postgres (free: 0.5GB) -----
DATABASE_URL=postgresql://user:pass@ep-xxx.us-east-2.aws.neon.tech/dbname?sslmode=require

# ----- Redis: Upstash (free: 10k commands/day) -----
REDIS_URL=rediss://default:xxx@xxx.upstash.io:6379

# ----- Email: Resend (free: 100/day, 3k/month) -----
RESEND_API_KEY=re_xxx

# ----- Error tracking: Sentry (free: 5k events/mo) -----
SENTRY_DSN=https://xxx@sentry.io/xxx

# ----- Local LLM via Ollama -----
OLLAMA_HOST=http://localhost:11434
OLLAMA_MODEL=qwen3:8b

# ----- E2B: sandboxed Python execution (free tier) -----
E2B_API_KEY=e2b_xxx

# =====================================================
# App-specific keys — fill ONLY what your app needs
# =====================================================

# --- PharmaIP Radar ---
USPTO_API_KEY=
PUBMED_API_KEY=
PUBMED_EMAIL=you@example.com

# --- CloudFinOps Co-Pilot ---
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
GCP_SERVICE_ACCOUNT_JSON_PATH=./gcp-creds.json
SLACK_BOT_TOKEN=xoxb-xxx
SLACK_SIGNING_SECRET=xxx
GITHUB_TOKEN=ghp_xxx
GITHUB_REPO_OWNER=your-org
GITHUB_REPO_NAME=cloud-cost-prs

# --- AutoHedge Pro ---
ALPACA_API_KEY=
ALPACA_SECRET_KEY=
ALPACA_PAPER=true
COINBASE_API_KEY=
COINBASE_SECRET=

# --- QuantaLab ---
ALPACA_API_KEY=
ALPACA_SECRET_KEY=
ALPACA_PAPER=true
INTERACTIVE_BROKERS_KEY=
