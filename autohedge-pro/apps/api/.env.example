# --- Database: Neon Postgres (free 0.5GB) ---
DATABASE_URL=postgresql+asyncpg://USER:PASS@HOST/DBNAME?sslmode=require

# --- Clerk Auth (free up to 10k MAU) ---
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_xxx
CLERK_SECRET_KEY=PLACEHOLDER
NEXT_PUBLIC_API_URL=http://localhost:8002

# --- Stripe (no monthly fee, pay per txn) ---
# Leave empty for dev bypass (returns demo URL)
STRIPE_SECRET_KEY=PLACEHOLDER
STRIPE_WEBHOOK_SECRET=PLACEHOLDER
STRIPE_PRICE_PRO=price_xxx_pro
STRIPE_PRICE_AUM=price_xxx_aum

# --- Alpaca (paper/live trading) ---
ALPACA_API_KEY=PLACEHOLDER
ALPACA_SECRET_KEY=PLACEHOLDER

# --- Redis: Upstash (free 10k cmd/day) ---
REDIS_URL=rediss://default:PASS@HOST.upstash.io:6379
